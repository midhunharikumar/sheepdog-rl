# =====================================================================
# Training / experiment artifacts (kept on disk, never committed).
# These are regenerated by examples/train_sb3.py and friends.
# =====================================================================
checkpoints/
models/
runs/
wandb/
watch_rollouts/
outputs/

# Generated rollout media at the repo root (demo.py, cem_solver.py, etc.).
# Curated showcase media lives under assets/ and is force-added below.
/*.gif
/*.png

# Model weights + VecNormalize stats. The curated pretrained PPO model is
# force-added below; everything else (bc, smoke, ad-hoc runs) stays out.
*.zip
*.pkl

# ---- Curated assets that ARE committed (override the rules above) ----
!assets/
!assets/**
!ppo_sheepdog.zip
!ppo_sheepdog_vecnorm.pkl
